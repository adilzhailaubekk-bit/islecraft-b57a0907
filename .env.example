# Supabase project URL, for example https://PROJECT_REF.supabase.co
SUPABASE_URL=

# Supabase public API key for server-side auth checks.
# Prefer the current Project Settings -> API -> Project API keys -> "publishable" key (starts with sb_publishable_).
# If your project only shows legacy JWT keys, use the current "anon public" key.
SUPABASE_PUBLISHABLE_KEY=

# Optional: only needed if backend code imports supabaseAdmin for admin/RLS-bypass actions
SUPABASE_SERVICE_ROLE_KEY=

# Public browser-safe Supabase values.
# IMPORTANT: Google OAuth token exchange will fail with UNAUTHORIZED_INVALID_API_KEY
# if this key is stale, from another project, or was copied with extra characters.
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Alternative name accepted by the app if your Supabase dashboard labels it anon/public
VITE_SUPABASE_ANON_KEY=
