# Supabase project URL, for example https://PROJECT_REF.supabase.co
SUPABASE_URL=

# Supabase anon/public key for server-side auth checks
SUPABASE_PUBLISHABLE_KEY=

# Optional: only needed if backend code imports supabaseAdmin for admin/RLS-bypass actions
SUPABASE_SERVICE_ROLE_KEY=

# Public browser-safe Supabase values
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Alternative name accepted by the app if your Supabase dashboard labels it anon/public
VITE_SUPABASE_ANON_KEY=

# Server-only Gemini API values. Never expose these as VITE_*.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
